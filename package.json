{
  "name": "dineway",
  "version": "1.0.0",
  "description": "Dineway — Restaurant Management Platform",
  "private": true,
  "scripts": {
    "install:all": "npm install && npm run install:server && npm run install:client && npm run install:admin && npm run install:superadmin",
    "install:server":     "cd server && npm install",
    "install:client":     "cd client && npm install",
    "install:admin":      "cd admin && npm install",
    "install:superadmin": "cd superadmin && npm install",
    "dev": "concurrently -n server,client,admin,superadmin -c cyan,green,yellow,magenta \"npm run dev:server\" \"npm run dev:client\" \"npm run dev:admin\" \"npm run dev:superadmin\"",
    "dev:server":     "cd server && npm run dev",
    "dev:client":     "cd client && npm run dev",
    "dev:admin":      "cd admin && npm run dev",
    "dev:superadmin": "cd superadmin && npm run dev",
    "build:client":     "cd client && npm run build",
    "build:admin":      "cd admin && npm run build",
    "build:superadmin": "cd superadmin && npm run build",
    "seed": "cd server && node seed.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
